{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "tsc: build",
			"command": "npx tsc -p ./",
			"problemMatcher": [
				"$tsc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"options": {
				"shell": {
					"executable": "cmd.exe",
					"args": ["/d", "/c"]
				}
			}
		}
	]
}
